# Local Development Environment Variables
# Copy this file to .env.local and adjust values as needed
# .env.local is NOT committed to git

# Environment
NODE_ENV=development
ENVIRONMENT=local

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/family_hub
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# API
API_PORT=3000
API_HOST=0.0.0.0

# Security
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRY=24h
BCRYPT_ROUNDS=10

# File Encryption
FILE_ENCRYPTION_KEY=your-encryption-key-here-change-in-production

# Third-party Services (optional for local development)
MERRIAM_WEBSTER_API_KEY=
OPEN_WEATHER_API_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@familyhub.local

# Google Drive (OAuth - optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google/callback

# Firebase (optional)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Feature Flags (Phase 1 - all enabled for local testing)
FEATURE_WORDLE_GAME=true
FEATURE_QUICKFIRE_TRIVIA=true
FEATURE_WORD_SCRAMBLE=true
FEATURE_HANGMAN_GAME=true
FEATURE_DAILY_QUESTS=true
FEATURE_HOMEWORK=true
FEATURE_KUNG_FU=true
FEATURE_HABITS=true
FEATURE_READING=true
FEATURE_MOOD_TRACKER=true
FEATURE_GUJARATI_MODULE=true
FEATURE_WEEKLY_GOALS=true
FEATURE_MONTHLY_GOALS=true
FEATURE_CATEGORY_MASTERY=true
FEATURE_DAILY_CHALLENGE=true
FEATURE_STREAK_RECOVERY=true
FEATURE_PARENT_PORTAL=true
FEATURE_GOOGLE_DRIVE_SYNC=true
FEATURE_HINT_TOKEN_SYSTEM=true
FEATURE_CHORE_POINTS=true
FEATURE_CHORE_BADGES=true
FEATURE_PRIVACY_MODE=true

# System Configuration
SYSTEM_TIMEZONE=UTC
SYSTEM_LANGUAGE=en

# Development Tools
DEBUG=false
MOCK_EXTERNAL_APIS=true
